# Copy to ~/.claracore/innerlife/innerlife.env and chmod 600.

INNERLIFE_ROOT=~/.claracore/innerlife

# Local Ollama / LM Studio:
INNERLIFE_LLM_BACKEND=openai_compatible
INNERLIFE_LLM_BASE_URL=http://127.0.0.1:11434/v1
INNERLIFE_LLM_API_KEY=
INNERLIFE_LIGHT_MODEL=gemma3:4b
INNERLIFE_DEEP_MODEL=gemma3:12b

# Enable only after bootstrapping sync cursors as documented in README.
INNERLIFE_MEMORIA_SYNC_AGENTS=
INNERLIFE_CONTINUITY_SYNC_AGENTS=

INNERLIFE_POLL_SECONDS=15
INNERLIFE_LIGHT_IDLE_SECONDS=7200
INNERLIFE_DEEP_IDLE_SECONDS=72000
INNERLIFE_AUTONOMY_ENABLED=true
